generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model agent_flows {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid())
  name      String
  config    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
